{
  "manifest_version": 3,
  "name": "URL Picker",
  "version": "0.1.0",
  "description": "Copy or download tab titles and URLs.",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
